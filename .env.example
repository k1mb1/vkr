NUXT_SESSION_PASSWORD=

NUXT_OAUTH_OIDC_CLIENT_ID=
NUXT_OAUTH_OIDC_CLIENT_SECRET=
NUXT_OAUTH_OIDC_OPENID_CONFIG=
NUXT_OAUTH_OIDC_REDIRECT_URL=http://front.localhost/auth/oidc

# Optional: post-logout redirect URL if your provider supports federated logout
NUXT_OIDC_POST_LOGOUT_REDIRECT_URL=http://front.localhost/

# Optional: backend service base URL for typed composable requests
NUXT_PUBLIC_BACKEND_BASE_URL=http://backend.localhost
NUXT_PUBLIC_SITE_ORIGIN=http://front.localhost

# Optional: demo mode for a public, no-login showcase (guest entry at /demo,
# seeded read-only data, no backend or OIDC required). Enable only on a demo
# deployment. When 'true', OIDC env vars above are not required.
NUXT_PUBLIC_DEMO_MODE=false
