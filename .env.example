NUXT_SESSION_PASSWORD=

# Casdoor OIDC
NUXT_OAUTH_OIDC_CLIENT_ID=
NUXT_OAUTH_OIDC_CLIENT_SECRET=
NUXT_OAUTH_OIDC_OPENID_CONFIG=https://<casdoor-host>/.well-known/openid-configuration

# IMPORTANT: the redirect URL, the host you open the app on, and the Redirect URL
# registered in the Casdoor application must all be the EXACT same origin (scheme +
# host + port). A mismatch loses the `nuxt-auth-state` cookie -> "state mismatch".
NUXT_OAUTH_OIDC_REDIRECT_URL=http://localhost:3000/auth/oidc

# Optional: post-logout redirect URL if your provider supports federated logout
NUXT_OIDC_POST_LOGOUT_REDIRECT_URL=http://localhost:3000/

# Optional: backend service base URL for typed composable requests
NUXT_PUBLIC_BACKEND_BASE_URL=http://localhost:8000
# Must match the origin you actually open the app on (and the redirect URL above)
NUXT_PUBLIC_SITE_ORIGIN=http://localhost:3000
