{
  "openapi": "3.1.0",
  "info": {
    "title": "VKR Backend API",
    "description": "API для управления учебным процессом: группы, студенты, предметы, преподаватели, занятия и посещаемость.",
    "contact": { "name": "k1mb1", "url": "https://github.com/k1mb1" },
    "license": {
      "name": "MIT License",
      "url": "https://opensource.org/licenses/MIT"
    },
    "version": "v1"
  },
  "servers": [
    { "url": "http://backend.localhost", "description": "Generated server url" }
  ],
  "security": [{ "bearerAuth": [] }],
  "tags": [
    { "name": "Groups", "description": "Управление группами и их составом" },
    { "name": "Subjects", "description": "Управление предметами" },
    { "name": "Lessons", "description": "Управление занятиями и расписанием" },
    { "name": "Teachers", "description": "Управление преподавателями" },
    {
      "name": "Subject Assignments",
      "description": "Teacher–Offering bindings"
    }
  ],
  "paths": {
    "/api/teachers/{id}": {
      "put": {
        "tags": ["Teachers"],
        "summary": "Создать или обновить преподавателя",
        "operationId": "createOrUpdateTeacher",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "ID преподавателя",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "requestBody": {
          "description": "Данные преподавателя",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateOrUpdateTeacherRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Преподаватель создан или обновлен",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TeacherResponse" }
              }
            }
          },
          "400": {
            "description": "Ошибка валидации",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorDto" }
              }
            }
          }
        }
      }
    },
    "/api/subjects": {
      "get": {
        "tags": ["Subjects"],
        "summary": "Get subjects page filtered by name",
        "operationId": "getPage",
        "parameters": [
          {
            "name": "name",
            "in": "query",
            "description": "Название предмета (частичное совпадение)",
            "required": false,
            "schema": {
              "type": "string",
              "description": "Название предмета (частичное совпадение)"
            }
          },
          {
            "name": "teacherId",
            "in": "query",
            "description": "ID учителя",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid",
              "description": "ID учителя"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Zero-based page index (0..N)",
            "required": false,
            "schema": { "type": "integer", "default": 0, "minimum": 0 }
          },
          {
            "name": "size",
            "in": "query",
            "description": "The size of the page to be returned",
            "required": false,
            "schema": { "type": "integer", "default": 20, "minimum": 1 }
          },
          {
            "name": "sort",
            "in": "query",
            "description": "Sorting criteria in the format: property,(asc|desc). Default sort order is ascending. Multiple sort criteria are supported.",
            "required": false,
            "schema": { "type": "array", "items": { "type": "string" } }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PagedModelSubjectPageResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Subjects"],
        "summary": "Создать предмет",
        "operationId": "createSubject",
        "requestBody": {
          "description": "Данные для создания предмета",
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateSubjectRequest" }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SubjectResponse" }
              }
            }
          }
        }
      }
    },
