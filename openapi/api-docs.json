  "components": {
    "schemas": {
      "CreateOrUpdateTeacherRequest": {
        "type": "object",
        "description": "Запрос на создание или обновление преподавателя",
        "properties": {
          "username": {
            "type": "string",
            "description": "Имя пользователя преподавателя",
            "minLength": 1
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "Email преподавателя",
            "minLength": 1
          }
        },
        "required": ["email", "username"]
      },
      "ErrorDto": {
        "type": "object",
        "description": "Стандартная модель ошибки API",
        "properties": {
          "status": {
            "type": "integer",
            "format": "int32",
            "description": "HTTP статус код"
          },
          "message": { "type": "string", "description": "Сообщение об ошибке" },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "Время возникновения ошибки"
          },
          "details": {
            "type": "string",
            "description": "Дополнительные детали ошибки (например, список валидационных ошибок)"
          }
        }
      },
      "TeacherResponse": {
        "type": "object",
        "description": "Информация о преподавателе",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "ID преподавателя"
          },
          "username": {
            "type": "string",
            "description": "Имя пользователя преподавателя"
          },
          "email": { "type": "string", "description": "Email преподавателя" },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "Дата создания"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "description": "Дата последнего обновления"
          }
        }
      },
      "CreateSubjectRequest": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "groupId": { "type": "string", "format": "uuid" },
          "teacherId": { "type": "string", "format": "uuid" }
        },
        "required": ["groupId", "name", "teacherId"]
      },
      "SubjectResponse": {
        "type": "object",
        "description": "Информация о предмете",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "ID предмета"
          },
          "name": { "type": "string", "description": "Название предмета" },
          "description": {
            "type": "string",
            "description": "Описание предмета"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "Дата создания"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "description": "Дата последнего обновления"
          }
        }
      },
      "CreateLessonsByTypeRequest": {
        "type": "object",
        "description": "Запрос на создание занятий по количеству типов",
        "properties": {
          "subjectId": {
            "type": "string",
            "format": "uuid",
            "description": "ID предмета"
          },
          "lectureCount": {
            "type": "integer",
            "format": "int32",
            "description": "Количество лекций"
          },
          "practiceCount": {
            "type": "integer",
            "format": "int32",
            "description": "Количество практик"
          }
        },
        "required": ["lectureCount", "practiceCount", "subjectId"]
      },
      "LessonResponse": {
        "type": "object",
        "description": "Информация о занятии",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "ID занятия"
          },
          "offeringId": {
            "type": "string",
            "format": "uuid",
            "description": "ID назначения предмета (offering)"
          },
          "subjectId": {
            "type": "string",
            "format": "uuid",
            "description": "ID предмета"
          },
          "groupId": {
            "type": "string",
            "format": "uuid",
            "description": "ID группы"
          },
          "subgroupId": {
            "type": "string",
            "format": "uuid",
            "description": "ID подгруппы (null для всей группы)"
          },
          "type": {
            "type": "string",
            "description": "Тип занятия",
            "enum": ["LECTURE", "PRACTICE"]
          },
          "teacherId": {
            "type": "string",
            "format": "uuid",
            "description": "ID преподавателя"
          },
          "startedAt": {
            "type": "string",
            "format": "date-time",
            "description": "Время начала занятия"
          },
          "endedAt": {
            "type": "string",
            "format": "date-time",
            "description": "Время окончания занятия"
          },
          "topic": { "type": "string", "description": "Тема занятия" },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "Дата создания"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "description": "Дата последнего обновления"
          }
        }
      },
      "BulkScheduleRequest": {
        "type": "object",
        "description": "Запрос на массовое создание занятий по недельному шаблону",
        "properties": {
          "subjectId": {
            "type": "string",
            "format": "uuid",
            "description": "ID предмета"
          },
          "schedules": {
            "type": "array",
            "description": "Список шаблонов расписания",
            "items": { "$ref": "#/components/schemas/Entry" },
            "minItems": 1
          }
        },
        "required": ["schedules", "subjectId"]
      },
      "Entry": {
        "type": "object",
        "description": "Элемент шаблона расписания",
        "properties": {
          "type": {
            "type": "string",
            "description": "Тип занятия",
            "enum": ["LECTURE", "PRACTICE"]
          },
          "startDate": {
            "type": "string",
            "format": "date",
            "description": "Дата начала (первая неделя)"
          },
          "totalCount": {
            "type": "integer",
            "format": "int32",
            "description": "Общее количество занятий",
            "minimum": 1
          },
          "daysOfWeek": {
            "type": "array",
            "description": "Дни недели по неделям. Внешний список — недели, внутренний — дни недели внутри недели",
            "items": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "MONDAY",
                  "TUESDAY",
                  "WEDNESDAY",
                  "THURSDAY",
                  "FRIDAY",
                  "SATURDAY",
                  "SUNDAY"
                ]
              },
              "minItems": 1
            },
            "minItems": 1
          }
        },
        "required": ["daysOfWeek", "startDate", "totalCount", "type"]
      },
