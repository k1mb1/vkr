            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": { "200": { "description": "OK" } }
      },
      "patch": {
        "tags": ["Subject Assignments"],
        "summary": "Update an existing teacher–offering binding (teacher / subgroup / lessonTypeScope)",
        "operationId": "update",
